rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'wlfmzhs@naver.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null &&
        request.auth.uid == uid;
    }

    function isKakaoOwner(userId) {
      return request.auth == null &&
        userId.matches('kakao_.+');
    }

    function isAnyUser() {
      return true;
    }

    function onlyAllowedJoinFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['participants', 'scores', 'partyId', 'partyIds', 'status', 'pointsAwarded', 'scoreBonusAwarded', 'pointAwardedUids', 'scoreAwardedUids']);
    }

    // 마감 처리(status를 closed로 변경)는 관리자만 가능
    function isClosingJoin() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']) &&
        request.resource.data.status == 'closed';
    }

    // 포인트/스탯 필드만 수정하는 경우 (조인 참가자가 타인 포인트 지급 시 사용)
    function onlyStatsFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['totalPoints', 'handicap', 'bestScore', 'roundCount', 'handicapTrend', 'statsUpdatedAt']);
    }

    // 결제 상태 필드는 서버(Cloud Function)만 기록 가능 — 회원이 스스로 못 바꿈
    function noBillingFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['isPaid', 'plan', 'subscriptionStatus', 'nextBillingDate', 'subscribedAt', 'canceledAt', 'lastBillingRunDate', 'grandfathered']);
    }

    match /users/{userId} {
      allow read: if isAnyUser();
      // 가입 시엔 isPaid:false 만 허용, plan/구독 필드는 넣을 수 없음 (관리자는 예외)
      allow create: if isAdmin() ||
        ((isOwner(userId) || isKakaoOwner(userId)) &&
          (!('isPaid' in request.resource.data) || request.resource.data.isPaid == false) &&
          !request.resource.data.keys().hasAny(['plan', 'subscriptionStatus', 'nextBillingDate', 'billingKey', 'grandfathered']));
      allow delete: if isOwner(userId) || isKakaoOwner(userId) || isAdmin();
      // 본인 문서는 수정 가능하되 결제 필드는 건드릴 수 없음 (관리자는 예외)
      allow update: if isAdmin() ||
        ((isOwner(userId) || isKakaoOwner(userId)) && noBillingFields()) ||
        (isLoggedIn() && onlyStatsFields());

      match /scoreHistory/{docId} {
        // 읽기: 본인/관리자 또는 유효한 조인이 있으면 누구나 (Kakao 비인증 유저도 동반자 스코어 열람 가능)
        allow read: if isOwner(userId) || isKakaoOwner(userId) || isAdmin() ||
          exists(/databases/$(database)/documents/joins/$(docId));
        // 쓰기: 본인/관리자 또는 로그인 유저가 유효한 조인에 저장하는 경우
        allow write: if isOwner(userId) || isKakaoOwner(userId) || isAdmin() ||
          (isLoggedIn() && exists(/databases/$(database)/documents/joins/$(docId)));
      }
    }

    match /joins/{joinId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (!isClosingJoin() && (
          (isAnyUser() && onlyAllowedJoinFields())
          || (isLoggedIn() && resource.data.creatorUid == request.auth.uid)
          || (isLoggedIn() && resource.data.participants.size() > 0 && resource.data.participants[0].uid == request.auth.uid)
          || (isKakaoOwner(resource.data.creatorUid))
          || (request.auth == null && resource.data.participants.size() > 0 && resource.data.participants[0].uid.matches('kakao_.+'))
        ));

      match /viewers/{viewerId} {
        allow read, write: if isAnyUser();
      }
    }

    match /subRounds/{roundId} {
      allow read: if isAnyUser();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isAnyUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['entries']));
    }

    match /courses/{courseId} {
      allow read, write: if isAnyUser();
    }

    match /notices/{noticeId} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    match /achievements/{achId} {
      allow read: if isAnyUser();
      allow create: if (isLoggedIn() && request.resource.data.uid == request.auth.uid) ||
        (request.auth == null && request.resource.data.uid.matches('kakao_.+'));
      allow update, delete: if isAdmin() ||
        (isLoggedIn() && resource.data.uid == request.auth.uid) ||
        (request.auth == null && resource.data.uid.matches('kakao_.+'));
    }

    match /pointHistory/{histId} {
      allow read: if isAnyUser();
      // 로그인한 참가자(Firebase) 또는 카카오 로그인 참가자가 제출 시 포인트 내역 생성 가능
      allow create: if isAdmin() || isLoggedIn() ||
        (request.auth == null && request.resource.data.uid.matches('kakao_.+'));
      allow update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      allow read, write: if isAnyUser();
    }

    match /tournaments/{tournamentId} {
      allow read: if isAnyUser();
      allow write: if isAdmin();

      match /registrations/{regId} {
        allow read: if isAnyUser();
        allow create: if isAnyUser();
        allow update, delete: if isAdmin();
      }

      match /scores/{scoreId} {
        allow read: if isAnyUser();
        allow write: if isAnyUser();
      }
    }

    match /inviteCodes/{code} {
      allow read: if isAnyUser();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        // 코드 소진: 미사용 → 사용
        (isAnyUser() &&
          resource.data.used == false &&
          request.resource.data.used == true &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedAt', 'usedBy'])) ||
        // 롤백: 방금 소진한 본인이 가입 저장 실패 시 되돌리기 (사용 → 미사용)
        (isAnyUser() &&
          resource.data.used == true &&
          resource.data.usedBy == request.auth.uid &&
          request.resource.data.used == false &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedAt', 'usedBy']));
    }

    match /banned/{uid} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    // 빌링키 등 결제 비밀정보 — 서버(Admin SDK)만 접근, 클라이언트 전면 차단
    match /billing/{uid} {
      allow read, write: if false;
    }

    // 결제 내역 — 본인/관리자만 열람, 기록은 서버만
    match /paymentHistory/{docId} {
      allow read: if isAdmin() ||
        (isLoggedIn() && resource.data.uid == request.auth.uid) ||
        (request.auth == null && resource.data.uid.matches('kakao_.+'));
      allow write: if false;
    }

    match /partnerInquiries/{inquiryId} {
      allow create: if isAnyUser();
      allow read, update, delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read, create: if isAnyUser();
        allow delete: if isAdmin() || isAnyUser();
      }
    }

    match /usedItems/{itemId} {
      allow read: if isAnyUser();
      // Firebase·카카오 모두 등록 가능
      allow create: if isLoggedIn() || isKakaoOwner(request.resource.data.sellerId);
      allow update: if isAdmin() ||
        // 누구나 조회수 증가
        (isAnyUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])) ||
        // ── 판매자 권한 ──
        // Firebase 판매자: 판매중일 때 상품 수정
        (isLoggedIn() && resource.data.sellerId == request.auth.uid && resource.data.status == 'sale') ||
        // 카카오 판매자: 판매중일 때 상품 수정
        (isKakaoOwner(resource.data.sellerId) && resource.data.status == 'sale') ||
        // Firebase 판매자: 발송준비 → 발송완료
        (isLoggedIn() && resource.data.sellerId == request.auth.uid &&
          resource.data.status == 'confirmed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // 카카오 판매자: 발송준비 → 발송완료
        (isKakaoOwner(resource.data.sellerId) && resource.data.status == 'confirmed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // ── 구매자 권한 ──
        // Firebase 구매자: 구매 신청 (판매중 → 입금대기)
        (isLoggedIn() && resource.data.status == 'sale' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','buyerId','buyerNick'])) ||
        // 카카오 구매자: 구매 신청 (판매중 → 입금대기)
        (isKakaoOwner(request.resource.data.buyerId) && resource.data.status == 'sale' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','buyerId','buyerNick'])) ||
        // Firebase 구매자: 수령 확인 (발송완료 → 거래완료)
        (isLoggedIn() && resource.data.buyerId == request.auth.uid &&
          resource.data.status == 'shipped' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // 카카오 구매자: 수령 확인 (발송완료 → 거래완료)
        (isKakaoOwner(resource.data.buyerId) && resource.data.status == 'shipped' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // ── 경매 입찰 ──
        // 일반 입찰
        (isAnyUser() && resource.data.isAuction == true && resource.data.auctionStatus == 'active' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'auctionCurrentBid','auctionHighestBidderUid','auctionHighestBidderNick','auctionBidCount'])) ||
        // 즉시구매 / 낙찰
        (isAnyUser() && resource.data.isAuction == true && resource.data.auctionStatus == 'active' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'auctionCurrentBid','auctionHighestBidderUid','auctionHighestBidderNick','auctionBidCount',
            'auctionStatus','status','buyerId','buyerNick']));
      allow delete: if isAdmin() ||
        (isLoggedIn() && resource.data.sellerId == request.auth.uid && resource.data.status == 'sale') ||
        (isKakaoOwner(resource.data.sellerId) && resource.data.status == 'sale');

      match /bids/{bidId} {
        allow read: if isAnyUser();
        allow create: if isAnyUser();
      }

      match /comments/{commentId} {
        allow read, create: if isAnyUser();
        allow delete: if isAdmin() ||
          (isLoggedIn() && resource.data.authorId == request.auth.uid) ||
          isKakaoOwner(resource.data.authorId);
      }
    }
  }
}
