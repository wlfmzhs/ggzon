rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'wlfmzhs@naver.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null &&
        request.auth.uid == uid;
    }

    function isKakaoOwner(userId) {
      return request.auth == null &&
        userId.matches('kakao_.+');
    }

    function isAnyUser() {
      return true;
    }

    function onlyAllowedJoinFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['participants', 'scores', 'partyId', 'status', 'pointsAwarded']);
    }

    // 포인트/스탯 필드만 수정하는 경우 (조인 참가자가 타인 포인트 지급 시 사용)
    function onlyStatsFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys().hasOnly(['totalPoints', 'handicap', 'bestScore', 'roundCount', 'handicapTrend', 'statsUpdatedAt']);
    }

    match /users/{userId} {
      allow read: if isAnyUser();
      allow create, delete: if isOwner(userId) || isKakaoOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isKakaoOwner(userId) || isAdmin() ||
        (isLoggedIn() && onlyStatsFields());

      match /scoreHistory/{docId} {
        // 읽기: 본인/관리자 또는 유효한 조인이 있으면 누구나 (Kakao 비인증 유저도 동반자 스코어 열람 가능)
        allow read: if isOwner(userId) || isKakaoOwner(userId) || isAdmin() ||
          exists(/databases/$(database)/documents/joins/$(docId));
        // 쓰기: 본인/관리자 또는 로그인 유저가 유효한 조인에 저장하는 경우
        allow write: if isOwner(userId) || isKakaoOwner(userId) || isAdmin() ||
          (isLoggedIn() && exists(/databases/$(database)/documents/joins/$(docId)));
      }
    }

    match /joins/{joinId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow delete: if isAdmin();
      allow update: if isAdmin() || (isAnyUser() && onlyAllowedJoinFields());

      match /viewers/{viewerId} {
        allow read, write: if isAnyUser();
      }
    }

    match /subRounds/{roundId} {
      allow read: if isAnyUser();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isAnyUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['entries']));
    }

    match /courses/{courseId} {
      allow read, write: if isAnyUser();
    }

    match /notices/{noticeId} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    match /achievements/{achId} {
      allow read: if isAnyUser();
      allow create: if (isLoggedIn() && request.resource.data.uid == request.auth.uid) ||
        (request.auth == null && request.resource.data.uid.matches('kakao_.+'));
      allow update, delete: if isAdmin() ||
        (isLoggedIn() && resource.data.uid == request.auth.uid) ||
        (request.auth == null && resource.data.uid.matches('kakao_.+'));
    }

    match /pointHistory/{histId} {
      allow read: if isAnyUser();
      // 로그인한 참가자가 제출 시 포인트 내역 생성 가능
      allow create: if isAdmin() || isLoggedIn();
      allow update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      allow read, write: if isAnyUser();
    }

    match /tournaments/{tournamentId} {
      allow read: if isAnyUser();
      allow write: if isAdmin();

      match /registrations/{regId} {
        allow read: if isAnyUser();
        allow create: if isAnyUser();
        allow update, delete: if isAdmin();
      }

      match /scores/{scoreId} {
        allow read: if isAnyUser();
        allow write: if isAnyUser();
      }
    }

    match /banned/{uid} {
      allow read: if isAnyUser();
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAnyUser();
      allow create: if isAnyUser();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read, create: if isAnyUser();
        allow delete: if isAdmin() || isAnyUser();
      }
    }

    match /usedItems/{itemId} {
      allow read: if isAnyUser();
      // 카카오 유저도 등록 가능
      allow create: if isLoggedIn() || isKakaoOwner(request.resource.data.sellerId);
      allow update: if isAdmin() ||
        // 판매자(Firebase)가 조회수 갱신
        (isLoggedIn() && resource.data.sellerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])) ||
        // 판매자(Firebase)가 상품 수정
        (isLoggedIn() && resource.data.sellerId == request.auth.uid &&
          resource.data.status == 'sale') ||
        // 판매자(카카오)가 상품 수정
        (isKakaoOwner(resource.data.sellerId) && resource.data.status == 'sale') ||
        // 구매자가 상태 변경
        (isLoggedIn() && resource.data.status == 'sale' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','buyerId','buyerNick'])) ||
        // 구매자가 수령 확인
        (isLoggedIn() && resource.data.buyerId == request.auth.uid &&
          resource.data.status == 'shipped' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // 판매자(Firebase)가 발송 처리
        (isLoggedIn() && resource.data.sellerId == request.auth.uid &&
          resource.data.status == 'confirmed' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        // 누구나 조회수 증가
        (isAnyUser() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])) ||
        // 입찰자가 경매 상태 업데이트 (일반 입찰)
        (isAnyUser() && resource.data.isAuction == true && resource.data.auctionStatus == 'active' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'auctionCurrentBid','auctionHighestBidderUid','auctionHighestBidderNick','auctionBidCount'])) ||
        // 입찰자가 즉시구매 또는 낙찰 처리
        (isAnyUser() && resource.data.isAuction == true && resource.data.auctionStatus == 'active' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'auctionCurrentBid','auctionHighestBidderUid','auctionHighestBidderNick','auctionBidCount',
            'auctionStatus','status','buyerId','buyerNick']));
      allow delete: if isAdmin() ||
        (isLoggedIn() && resource.data.sellerId == request.auth.uid && resource.data.status == 'sale') ||
        // 카카오 판매자도 자기 상품 삭제 가능
        (isKakaoOwner(resource.data.sellerId) && resource.data.status == 'sale');

      match /bids/{bidId} {
        allow read: if isAnyUser();
        allow create: if isAnyUser();
      }

      match /comments/{commentId} {
        allow read, create: if isAnyUser();
        allow delete: if isAdmin() ||
          (isLoggedIn() && resource.data.authorId == request.auth.uid) ||
          isKakaoOwner(resource.data.authorId);
      }
    }
  }
}
